APP_ENV=development
DEBUG=true

BOT_TOKEN=your_telegram_bot_token
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_BASE_URL=http://localhost:8000
# local miniapp can call backend directly through this
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
# Railway miniapp can proxy /api to the backend using this internal/public URL
BACKEND_INTERNAL_URL=
POSTGRES_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:55432/ai_bot_db
REDIS_URL=redis://127.0.0.1:6379/0

MINIAPP_URL=https://your-miniapp-domain.example
ALLOWED_DEV_ORIGINS=

SECRET_KEY=muzaffar

DEFAULT_LANGUAGE=ru
AI_MOCK_MODE=false
GENERATION_PROCESS_NOW=false
CELERY_TASK_ALWAYS_EAGER=false
GENERATION_POLL_INTERVAL_SECONDS=2
GENERATION_POLL_ATTEMPTS=90
GENERATION_CALLBACK_BASE_URL=

# AI providers
NANO_BANANA_PROVIDER=kie
KLING_PROVIDER=kie
VEO_PROVIDER=kie

KIE_API_KEY=your_kie_api_key
KIE_BASE_URL=https://api.kie.ai

# logical keys for future flexibility
NANO_BANANA_API_KEY=
KLING_API_KEY=
VEO_API_KEY=

# for real Kie generation switch mock mode off
# AI_MOCK_MODE=false
# if you want non-blocking jobs in bot/miniapp, run the worker and switch this off too
# GENERATION_PROCESS_NOW=false

# ID администраторов через запятую
ADMIN_IDS=123456789,987654321

# Payments (stars | click | payme)
PAYMENT_PROVIDER=stars

PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
