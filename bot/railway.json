{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "python -m pip install -r ../requirements.txt",
    "watchPatterns": [
      "/backend/**",
      "/bot/**",
      "/shared/**",
      "/locales/**",
      "/requirements.txt"
    ]
  },
  "deploy": {
    "startCommand": "PYTHONPATH=.. python -m bot.main",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": "V2"
  }
}
