{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "sh scripts/railway/build-miniapp.sh",
    "watchPatterns": [
      "/miniapp/**",
      "/scripts/railway/**"
    ]
  },
  "deploy": {
    "startCommand": "sh scripts/railway/start-miniapp.sh",
    "healthcheckPath": "/",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": "V2"
  }
}
